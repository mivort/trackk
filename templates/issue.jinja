{#- Date display macro -#}
{% macro entry_date(date) %}
  {%- if date -%}
    {{ fg(lightwhite) }}{{ date | datefmt('long') }}{{ reset }}
    {%- if cols > 60 -%}
      {#- #} ({{ date | longreldate }})
    {%- endif -%}
  {%- else -%}
    {{ fg(lightblack) }}--{{ reset }}
  {%- endif -%}
{% endmacro %}

{#- Tag list -#}
{%- set tags -%}
  {%- if entry.tags | length > 0 -%}
    {%- for tag in entry.tags -%}
      {{ fg(magenta) }}#{{ fg(lightmagenta) }}{{ tag }} {# -#}
    {%- endfor -%}
  {%- else -%}
    {{ fg(lightblack) }}--
  {%- endif -%}
  {{ reset }}
{%- endset -%}

{#- Line break -#}
{%- set break -%}
  {% if cols < 44 %}{{ "\n * " }}{% endif %}
{%- endset -%}

{#- Max width -#}
{%- set maxw = min(cols, 96) -%}

{#- Field output -#}
{{ fg(blue) }}{{ fill('-', maxw) }}{{ reset }}
{{ entry.title }}
{{ fg(blue) }}{{ fill('-', maxw) }}{{ reset }}
{{ fg(lightblue) }} Status:   {{ reset }}{{ entry.status }}
{{ fg(lightblue) }} Created:  {{ reset }}{{ break }}{{ entry_date(entry.created) }}
{{ fg(lightblue) }} Modified: {{ reset }}{{ break }}{{ entry_date(entry.modified) }}
{{ fg(lightblue) }} Due:      {{ reset }}{{ break }}{{ entry_date(entry.due) }}
{{ fg(lightblue) }} End:      {{ reset }}{{ break }}{{ entry_date(entry.end) }}
{{ fg(lightblue) }} Repeat:   {{ reset }}{{ entry.repeat | default(fg(lightblack) ~ "--") }}
{{ fg(lightblue) }} Tags:     {{ reset }}{{ tags }}

{{ fg(lightblue) }} Urgency:  {{ reset }}{{ urgency | numfmt('{:.3}') }}

{% if sid -%}
  {{ fg(lightblue) }} SID:      {{ reset }}{{ sid }}
{% endif -%}
{{ fg(lightblue) }} UUID:     {{ reset }}{{ break }}{{ entry.id | trunc(maxw - 3) }}
{{ fg(lightblue) }} Path:     {{ reset }}{{ path }}
{{ fg(blue) }}{{ fill('-', min(cols, 96)) }}{{ reset }}
