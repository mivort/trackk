{#- Issue title -#}
{%- set title -%}{{ fg(lightcyan) }}{{ issue.title | firstline }}{%- endset -%}
{%- set titlew = title | width -%}

{#- Meta section -#}
{%- set meta -%}
{{ fg(13) -}}
{% for tag in issue.tags %}<{{ tag }}> {% endfor %}
{{- reset -}}
/ 0d
{%- endset -%}
{%- set metaw = meta | width -%}

{#- Shorthand ID -#}
{{ fg(lightblue) }}{{ "{:3}. " | format(sid | default("    ", true)) }}

{#- Row output -#}
{{ title -}}
{{ reset }} {{ fill('.', min(cols, 96) - titlew - metaw - 8) }} {{ meta }}
