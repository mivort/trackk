{#- Max rendering width -#}
{%- set maxw = min(cols, 96) -%}

{#- Limit amount of visible tags based on terminal width -#}
{%- set taglimit = 2 if cols > 56 else 1 -%}

{#- Entry details section -#}
{%- set meta -%}
  {#- Tag list -#}
  {%- if cols > 32 -%}
    {%- for tag in entry.tags | batch(taglimit) | first -%}
      {{ fg(magenta) }}#{{ fg(lightmagenta) }}{{ tag }} {# -#}
    {%- endfor -%}
    {% if entry.tags | length > taglimit -%}
      {{ fg(magenta) }}+{{ entry.tags | length - taglimit }} {# -#}
    {% endif -%}
  {%- endif -%}
  {{- reset -}}

  {#- Due date -#}
  {%- if entry.due and cols > 36 and entry.status != 'complete' and entry.status != 'deleted' -%}
    / {# -#}
    {%- if entry.due >= now -%}
      {{ fg(lightwhite) }}
    {%- else -%}
      {{ fg(lightred) }}
    {%- endif -%}
    {{ entry.due | reldate }}{{ reset }} {# -#}
  {%- endif -%}

  {#- Urgency -#}
  {%- if cols > 48 -%}
    / {{ fg(green) }}{{ urgency | numfmt('{:.1}') }}{{ reset }} {# -#}
  {%- endif -%}
{%- endset -%}
{%- set metaw = meta | width -%}

{#- Entry status -#}
{%- set status -%}
  {%- if entry.status == 'blocked' -%}
    {{ fg(red) }} ||
  {%- elif entry.status == 'started' -%}
    {{ fg(lightblue) }} >>
  {%- endif -%}
{%- endset -%}
{%- set statusw = status | width -%}

{#- Entry title -#}
{%- set title | trunc(maxw - statusw - metaw - 6, '…') -%}
  {%- if entry.status == 'deleted' -%}
    {{ fg(lightblack) }}
  {%- elif entry.status == 'complete' -%}
    {{ fg(green) }}
  {%- else -%}
    {{ fg(white) }}
  {%- endif -%}
  {{ entry.desc | firstline }}
{%- endset -%}
{%- set titlew = title | width -%}

{#- Shorthand ID -#}
{%- set number -%}
  {%- if sid -%}
    {{ sid | numfmt('{:3}. ') }}
  {%- else -%}
    {{ entry.id[0:4] }} {# -#}
  {%- endif -%}
{%- endset -%}
{%- set numberw = number | width -%}
{%- set numbercolor -%}
  {%- if entry.status == 'deleted' -%}
    {{ fg(lightblack) }}
  {%- elif entry.status == 'complete' -%}
    {{ fg(lightgreen) }}
  {%- elif sid -%}
    {{ fg(lightblue) }}
  {%- else -%}
    {{ fg(blue) }}
  {%- endif -%}
{%- endset -%}

{#- Row output -#}
{{- numbercolor -}}{{- number -}}
{{- title -}}{{ reset }}{{ status -}}
{{- fg(lightblack) }}{{ fill('.', maxw - statusw - titlew - metaw - numberw - 1) }} {# -#}
{{- meta -}}

{% if lineno == count - 1 %}
{% endif %}
