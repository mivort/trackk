{#- Issue title -#}
{%- set title -%}{{ issue.title | firstline }}{%- endset -%}
{%- set titlew = title | width -%}

{#- Meta section -#}
{%- set meta -%}{{ fg(10) }}[{{ issue.tags | length }}]{{ reset }}{%- endset -%}
{%- set metaw = meta | width -%}

{#- Shorthand ID -#}
{{ fg(brightblue) }}{{ "{:3}. " | format(sid | default("    ", true)) }}

{#- Row output -#}
{{ fg(brightgreen) }}{{ title -}}
{{ reset }} {{ fill('.', min(cols, 96) - titlew - metaw - 8) }} {{ meta }}
