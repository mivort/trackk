{#-
  Max rendering width depending on terminal width ('cols').
-#}
{%- set maxw = min(cols, 96) -%}

{#-
  Limit amount of visible tags based on terminal width.
  Defines a breakpoint which compacts the tag display.
-#}
{%- set taglimit = 2 if cols > 64 else 1 -%}

{#-
  Entry details section.
  Some of details get hidden when terminal width is small.
-#}
{%- set meta -%}
  {#- Tag list -#}
  {%- if cols > 32 -%}
    {%- for tag in entry.tags | batch(taglimit) | first -%}
      {{ fg(lightmagenta) }}+{{ tag }} {# -#}
    {%- endfor -%}
    {% if entry.tags | length > taglimit -%}
      {{ fg(magenta) }}+{{ entry.tags | length - taglimit }} {# -#}
    {% endif -%}
  {%- endif -%}
  {{- reset -}}

  {#- When/due date -#}
  {%- if cols > 36 and not entry.end -%}
    {%- if entry.due -%}
      {%- if entry.due >= now -%}
        / {{ fg(lightwhite) }}
      {%- else -%}
        / {{ fg(lightred) }}
      {%- endif -%}
      {{ entry.due | reldate }} {{ reset }}
    {%- elif entry.when -%}
      / {{ fg(lightblue) }}{{ entry.when | reldate }} {{ reset }}
    {%- endif -%}
  {%- endif -%}

  {#- End date -#}
  {%- if entry.end and cols > 36 -%}
    / {{ fg(cyan) }}{{ (2 * now - entry.end) | reldate }}{{ reset }} {# -#}
  {%- endif -%}

  {#- Urgency -#}
  {%- if cols > 48 and not entry.end -%}
    / {{ fg(green) }}{{ urgency | numfmt('{:.1}') }}{{ reset }} {# -#}
  {%- endif -%}
{%- endset -%}
{%- set metaw = meta | width -%}

{#- Entry status -#}
{%- set status -%}
  {%- if entry.status == 'blocked' -%}
    {{ fg(red) }} ||
  {%- elif entry.status == 'started' -%}
    {{ fg(lightblue) }} >>
  {%- endif -%}
  {%- if entry.repeat -%}
    {{ fg(cyan) }} /r
  {%- endif -%}
  {%- if cols > 64 and entry.desc | hasnote -%}
    {{ fg(cyan) }} /n
  {%- endif -%}
{%- endset -%}
{%- set statusw = status | width -%}

{#-
  Entry title.
  Color depends on the current status.
-#}
{%- set title | trunc(maxw - statusw - metaw - 6, '…') -%}
  {%- if entry.status == 'deleted' -%}
    {{ fg(lightblack) }}
  {%- elif entry.status == 'completed' -%}
    {{ fg(green) }}
  {%- else -%}
    {{ reset }}
  {%- endif -%}
  {{ entry.desc | firstline }}
{%- endset -%}
{%- set titlew = title | width -%}

{#-
  Shorthand ID ('sid').
  If no shorthand is available, trimmed version of UUID is shown.
-#}
{%- set number -%}
  {%- if sid -%}
    {{ sid | numfmt('{:3}. ') }}
  {%- else -%}
    {{ entry.id[0:4] }} {# -#}
  {%- endif -%}
{%- endset -%}
{%- set numberw = number | width -%}

{#-
  ID color depending on the entry's status.
-#}
{%- set numbercolor -%}
  {%- if entry.status == 'deleted' -%}
    {{ fg(lightblack) }}
  {%- elif entry.status == 'completed' -%}
    {{ fg(lightgreen) }}
  {%- elif sid -%}
    {{ fg(lightblue) }}
  {%- else -%}
    {{ fg(blue) }}
  {%- endif -%}
{%- endset -%}

{#-
  Row output.
  Combines together previously defined components and adds a filler in the middle.

  [ number ] [ title ] [ status icons ] [ ....... filler ....... ] [ meta ]
-#}
{{- numbercolor -}}{{- number -}}
{{- title -}}{{ reset }}{{ status -}}
{{- fg(lightblack) }}{{ fill('.', maxw - statusw - titlew - metaw - numberw - 1) }} {# -#}
{{- meta -}}

{#-
  Add new line on the last entry.
  If limit is set, show the amount of entries outside the limit count.
-#}
{%- if lineno == limit - 1 %}
{# #}
  {%- if lineno != count - 1 -%}
    {# #}     {{ fg(lightblack) }}+{{ count - limit }} more{{ reset }}
  {%- endif -%}
{%- endif %}
