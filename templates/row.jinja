{#- Meta section -#}
{%- set meta -%}
{{ fg(13) -}}
{% for tag in issue.tags | batch(2) | first %}<{{ tag }}> {% endfor -%}
{% if issue.tags | length > 2 %}<+{{ issue.tags | length - 2 }}> {% endif -%}
{{- reset -}}
/ 0d
{%- endset -%}
{%- set metaw = meta | width -%}

{#- Max width -#}
{%- set maxw = min(cols, 96) -%}

{#- Issue title -#}
{%- set title | trunc(maxw - metaw - 8) -%}{{ fg(lightcyan) }}{{ issue.title | firstline }}{%- endset -%}
{%- set titlew = title | width -%}

{#- Shorthand ID -#}
{{ fg(lightblue) }}{{ "{:3}. " | format(sid | default("    ", true)) }}

{#- Row output -#}
{{ title -}}
{{ reset }} {{ fill('.', maxw - titlew - metaw - 8) }} {{ meta }}
