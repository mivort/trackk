{#- Max rendering width -#}
{%- set maxw = min(cols, 96) -%}

{#- Limit amount of visible tags based on terminal width -#}
{%- set taglimit = 2 if cols > 56 else 1 -%}

{#- Entry details section -#}
{%- set meta -%}
  {#- Tag list -#}
  {%- if cols > 32 -%}
    {%- for tag in entry.tags | batch(taglimit) | first -%}
      {{ fg(magenta) }}#{{ fg(lightmagenta) }}{{ tag }} {# -#}
    {%- endfor -%}
    {% if entry.tags | length > taglimit -%}
      {{ fg(magenta) }}+{{ entry.tags | length - taglimit }} {# -#}
    {% endif -%}
  {%- endif -%}
  {{- reset -}}

  {#- Due date -#}
  {%- if cols > 36 -%}
    {%- if entry.due -%}
      / {# -#}
      {%- if entry.due >= now -%}
        {{ fg(lightwhite) }}
      {%- else -%}
        {{ fg(lightred) }}
      {%- endif -%}
      {{ entry.due | reldate }}{{ reset }} {# -#}
    {%- else -%}
      / {{ fg(lightblack) }}..{{ reset }} {# -#}
    {%- endif -%}
  {%- endif -%}

  {#- Urgency -#}
  {%- if cols > 48 -%}
    / {{ fg(green) }}{{ urgency | numfmt('{:.1}') }}{{ reset }} {# -#}
  {%- endif -%}
{%- endset -%}
{%- set metaw = meta | width -%}

{#- Entry title -#}
{%- set title | trunc(maxw - metaw - 6, '…') -%}
  {%- if entry.status == 'blocked' -%}
    {{ fg(red) }}[b] {# -#}
  {%- endif -%}
  {{ fg(lightcyan) }}{{ entry.title | firstline }}
{%- endset -%}
{%- set titlew = title | width -%}

{#- Shorthand ID -#}
{%- if sid -%}
{{ fg(lightblue) }}{{ sid | numfmt('{:3}. ') }}
{%- else -%}
  {{ fg(blue) }}{{ entry.id[0:4] }} {# -#}
{%- endif -%}

{#- Row output -#}
{{ title -}}
{{ reset }}{{ fg(lightblack) }}{{ fill('.', maxw - titlew - metaw - 6) }} {{ meta }}
